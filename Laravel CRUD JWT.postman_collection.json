        {
          "name": "Login",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Pastikan credentials tersedia",
                  "const email = pm.environment.get('login_email');",
                  "const password = pm.environment.get('login_password');",
                  "",
                  "if (!email || !password) {",
                  "    console.warn('login_email / login_password belum di-set di environment!');",
                  "    console.warn('Jalankan Register terlebih dahulu atau set manual di environment.');",
                  "} else {",
                  "    console.log('Mencoba login dengan:', email);",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Test 1: Status 200",
                  "pm.test('Status 200 - OK', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "// Test 2: Ada field status = success",
                  "pm.test('Status response = success', function() {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.status).to.eql('success');",
                  "});",
                  "",
                  "// Test 3: Token JWT valid (format 3 bagian dipisah titik)",
                  "pm.test('JWT Token format valid', function() {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.token).to.be.a('string');",
                  "    const parts = json.token.split('.');",
                  "    pm.expect(parts).to.have.lengthOf(3);",
                  "});",
                  "",
                  "// Test 4: Ada data user",
                  "pm.test('Data user tersedia di response', function() {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.user).to.have.property('id');",
                  "    pm.expect(json.user).to.have.property('email');",
                  "});",
                  "",
                  "// Auto-save token ke environment",
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    pm.environment.set('jwt_token', json.token);",
                  "    pm.environment.set('current_user_id', json.user.id);",
                  "    pm.environment.set('current_user_email', json.user.email);",
                  "",
                  "    // Decode JWT payload untuk info",
                  "    try {",
                  "        const payload = json.token.split('.')[1];",
                  "        const decoded = JSON.parse(atob(payload));",
                  "        pm.environment.set('jwt_expires_at', new Date(decoded.exp * 1000).toISOString());",
                  "        console.log('Token expire:', new Date(decoded.exp * 1000).toLocaleString());",
                  "    } catch(e) {}",
                  "",
                  "    console.log('Login berhasil! Token tersimpan.');",
                  "    console.log('User ID:', json.user.id);",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
