                  "pm.test('Setiap user memiliki array hobbies', function() {",
                  "    const json = pm.response.json();",
                  "    if (json.data.length > 0) {",
                  "        json.data.forEach(function(user) {",
                  "            pm.expect(user).to.have.property('hobbies');",
                  "            pm.expect(user.hobbies).to.be.an('array');",
                  "        });",
                  "    }",
                  "});",
                  "",
                  "// Test 4: Password tidak terekspos",
                  "pm.test('Password tidak terekspos di list users', function() {",
                  "    const json = pm.response.json();",
                  "    if (json.data.length > 0) {",
                  "        json.data.forEach(function(user) {",
                  "            pm.expect(user).to.not.have.property('password');",
                  "        });",
                  "    }",
                  "});",
                  "",
                  "// Simpan ID user pertama untuk test berikutnya",
                  "const json = pm.response.json();",
                  "if (json.data && json.data.length > 0) {",
