              "raw": "{\n    \"name\": \"Admin User\",\n    \"email\": \"{{register_email}}\",\n    \"password\": \"{{register_password}}\",\n    \"password_confirmation\": \"{{register_password}}\"\n}",
              "options": {
                "raw": {
