    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Generate email unik agar tidak conflict",
                  "const timestamp = Date.now();",
                  "const randomEmail = `user_${timestamp}@example.com`;",
                  "",
                  "// Simpan ke environment untuk dipakai di body",
                  "pm.environment.set('register_email', randomEmail);",
                  "pm.environment.set('register_password', 'password123');",
                  "",
                  "console.log(' Email yang akan didaftarkan:', randomEmail);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Test 1: Status code 201",
                  "pm.test('Status 201 - Created', function() {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "// Test 2: Response punya field status",
                  "pm.test('Response memiliki field status', function() {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('status');",
                  "    pm.expect(json.status).to.eql('success');",
                  "});",
                  "",
                  "// Test 3: Response punya token",
                  "pm.test('Response memiliki JWT token', function() {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('token');",
                  "    pm.expect(json.token).to.be.a('string').and.not.empty;",
                  "});",
                  "",
                  "// Test 4: Data user ada di response",
                  "pm.test('Data user ada di response', function() {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('user');",
                  "    pm.expect(json.user).to.have.property('id');",
                  "    pm.expect(json.user).to.have.property('name');",
                  "    pm.expect(json.user).to.have.property('email');",
                  "});",
                  "",
                  "// Simpan token & data user ke environment",
                  "if (pm.response.code === 201) {",
                  "    const json = pm.response.json();",
                  "    pm.environment.set('jwt_token', json.token);",
                  "    pm.environment.set('current_user_id', json.user.id);",
                  "    pm.environment.set('current_user_email', json.user.email);",
                  "    console.log('Token JWT tersimpan!');",
                  "    console.log('User ID:', json.user.id);",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
